rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isManager()    { return isAuth() && (role() == 'clinic_manager' || role() == 'manager'); }
    function isPhysio()     { return isAuth() && role() == 'physiotherapist';  }
    function isSecretary()  { return isAuth() && role() == 'secretary';        }
    function isPatient()    { return isAuth() && role() == 'patient';          }
    function isPhysician()  { return isAuth() && role() == 'physician';        }
    function isStaff()      { return isManager() || isPhysio() || isSecretary(); }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can read/update their own profile; manager can read all.
    match /users/{uid} {
      allow read:  if isAuth() && (request.auth.uid == uid || isManager());
      allow write: if isAuth() && (request.auth.uid == uid || isManager());
    }

    // ── Physiotherapists ──────────────────────────────────────────────────────
    match /physiotherapists/{uid} {
      allow read:  if isStaff() || isPatient();
      allow write: if isManager() || (isPhysio() && request.auth.uid == uid);
    }

    // ── Secretaries ───────────────────────────────────────────────────────────
    match /secretaries/{uid} {
      allow read:  if isStaff();
      allow write: if isManager();
    }

    // ── Physicians ────────────────────────────────────────────────────────────
    match /physicians/{uid} {
      allow read:  if isStaff() || isPhysician();
      allow write: if isManager();
    }

    // ── Physician Notes ───────────────────────────────────────────────────────
    match /physicianNotes/{docId} {
      allow read:   if isStaff() || isPhysician();
      allow create: if isPhysician() && request.resource.data.physicianId == request.auth.uid;
      allow update: if isManager() || (isPhysician() && resource.data.physicianId == request.auth.uid);
      allow delete: if isManager() || (isPhysician() && resource.data.physicianId == request.auth.uid);
    }

    // ── Patients ──────────────────────────────────────────────────────────────
    match /patients/{patientId} {
      allow read:            if isAuth();
      allow create:          if isStaff() || (isAuth() && request.auth.uid == patientId);
      allow update, delete:  if isStaff();
    }

    // ── Patient sub-collections ───────────────────────────────────────────────
    match /patientProfiles/{patientId} {
      allow read:  if isAuth();
      allow write: if isStaff();
    }

    match /patientAssessments/{patientId} {
      allow read:  if isStaff() || isPhysician();
      allow write: if isManager() || isPhysio();
    }

    match /patientDiagnosis/{patientId} {
      allow read:  if isStaff() || isPhysician();
      allow write: if isManager() || isPhysio();
    }

    match /patientSessions/{docId} {
      allow read:  if isStaff() || isPatient() || isPhysician();
      allow write: if isManager() || isPhysio();
    }

    match /patientDocuments/{docId} {
      allow read:   if isStaff() || isPatient() || isPhysician();
      allow create: if isStaff() || (isPatient() && request.resource.data.uploadedBy == request.auth.uid && request.resource.data.patientId == request.auth.uid);
      allow update: if isStaff();
      allow delete: if isStaff() || (isPatient() && resource.data.patientId == request.auth.uid && resource.data.uploadedBy == request.auth.uid);
    }

    match /patientExercises/{docId} {
      allow read:          if isStaff() || isPatient() || isPhysician();
      allow create, delete: if isManager() || isPhysio();
      allow update:        if isManager() || isPhysio() || isPatient();
    }

    match /assignedExercises/{docId} {
      allow read:  if isStaff() || isPatient();
      allow write: if isManager() || isPhysio();
    }

    match /sessionFeedback/{docId} {
      allow read:          if isStaff() || isPatient();
      allow create:        if isStaff() || (isPatient() && request.resource.data.patientId == request.auth.uid);
      allow update, delete: if isStaff();
    }

    // ── Body Profile (Joint Assessment) ───────────────────────────────────────
    // Clinic manager: full access.
    // Physiotherapist: full access (senior assignment enforced in app layer).
    match /jointAssessments/{patientId} {
      allow read:  if isStaff();
      allow write: if isManager() || isPhysio();
    }

    // ── Appointments ─────────────────────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow read:          if isStaff() || isPatient();
      allow create:        if isStaff() || (isPatient() && request.resource.data.patientId == request.auth.uid);
      allow update:        if isStaff();
      allow delete:        if isStaff() || (isPatient() && resource.data.patientId == request.auth.uid);
    }

    // ── Exercise Library ─────────────────────────────────────────────────────
    match /exerciseLibrary/{exerciseId} {
      allow read:  if isStaff();
      allow write: if isManager() || isPhysio();
    }

    // ── Treatment Protocols ───────────────────────────────────────────────────
    // All staff can read; only manager can create / edit / delete.
    match /treatmentProtocols/{protocolId} {
      allow read:  if isStaff();
      allow write: if isManager();
    }

    // ── Diagnosis Templates ───────────────────────────────────────────────────
    // All physio staff can read; manager and senior physios can write.
    match /diagnosisTemplates/{templateId} {
      allow read:  if isManager();
      allow write: if isManager();
    }

    // ── Patient Protocol Assignments ──────────────────────────────────────────
    // All physios and manager can assign; all staff can read.
    match /patientProtocols/{docId} {
      allow read:  if isStaff();
      allow write: if isManager() || isPhysio();
    }

    // ── Clinic Settings ──────────────────────────────────────────────────────
    match /clinicSettings/{docId} {
      allow read:  if isStaff() || isPatient();
      allow write: if isManager();
    }

    // ── Schedule ─────────────────────────────────────────────────────────────
    match /schedule/{docId} {
      allow read:  if isStaff();
      allow write: if isManager();
    }

    // ── Billing & Pricing (manager + secretary only) ─────────────────────────
    match /patientBilling/{docId} {
      allow read:          if isManager() || isSecretary();
      allow write:         if isManager() || isSecretary();
    }

    match /patientSessionPrices/{docId} {
      allow read:          if isManager() || isSecretary() || isPhysio();
      allow write:         if isManager() || isSecretary();
    }

    match /patientPackages/{docId} {
      allow read:          if isManager() || isSecretary() || isPhysio();
      allow write:         if isManager() || isSecretary() || isPhysio();
    }

    // ── Daily Check-ins ───────────────────────────────────────────────────────
    // Doc ID: {patientId}_{YYYY-MM-DD}
    match /dailyCheckIns/{docId} {
      allow read:          if isStaff() || isPatient();
      allow create, update: if isPatient() && request.resource.data.patientId == request.auth.uid;
      allow delete:        if isManager();
    }

    // ── Exercise Streak Log ───────────────────────────────────────────────────
    // Doc ID: {patientId}_{YYYY-MM-DD} — written when patient completes any exercise
    match /exerciseStreakLog/{docId} {
      allow read:          if isStaff() || isPatient();
      allow create, update: if isPatient() && request.resource.data.patientId == request.auth.uid;
      allow delete:        if isManager();
    }

    // ── Online Rehabilitation ─────────────────────────────────────────────────
    match /onlineRehabEnrollments/{docId} {
      allow read:  if isStaff() || isPhysician();
      allow write: if isManager() || isPhysio();
    }

    match /onlineRehabPrograms/{docId} {
      allow read:  if isStaff() || isPhysician();
      allow write: if isManager() || isPhysio();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Per-user subcollection: notifications/{userId}/items/{notifId}
    // Each staff member can read/write their own notifications.
    // Any authenticated staff can create notifications for any user (fanout).
    match /notifications/{userId}/items/{notifId} {
      allow read, update, delete: if isAuth() && request.auth.uid == userId;
      allow create:               if isStaff();
    }

    // ── WhatsApp Sessions ─────────────────────────────────────────────────────
    // Doc ID: normalized phone number — stores conversation history
    // Only Cloud Functions (admin SDK) write here; no client access needed.
    match /whatsappSessions/{phone} {
      allow read, write: if false; // admin SDK only
    }

  }
}
